# =========================
mobile-app/node_modules/
mobile-app/.expo/
mobile-app/dist/
mobile-app/web-build/

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# Python / ML Service
# =========================
ml-service/__pycache__/
ml-service/*.pyc
ml-service/.venv/
ml-service/venv/
ml-service/*.egg-info/

# =========================
# Environment & Secrets
# =========================
.env
.env.*
application-local.properties

# =========================
# IDE
# =========================
.idea/
.vscode/
*.iml

